# APPLICATION ENVIRONMENT
APP_ENV=local
USE_MINIO=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,backend,worker

# DATABASE CONFIGURATION
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@db:5432/document_backend
DATABASE_SYNC_URL=postgresql://<DB_USER>:<DB_PASSWORD>@db:5432/document_backend
DATABASE_USERNAME=<DB_USER>
DATABASE_PASSWORD=<DB_PASSWORD>
DB_PORT=5432

# REDIS CONFIGURATION
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# JWT CONFIGURATION
SECRET_KEY='<YOUR_SECRET_KEY>'
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM="HS256"

# GEMINI API KEY
GEMINI_API="<YOUR_GEMINI_API_KEY>"

# STORAGE CONFIGURATION
# Options: local, minio, r2
STORAGE_TYPE=local

# MINIO CONFIGURATION (if using)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=document-bucket
MINIO_SECURE=False
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# S3 / R2 CONFIGURATION (Cloudflare R2)
S3_BUCKET=document-bucket
S3_ENDPOINT=<YOUR_S3_ENDPOINT>
S3_ACCESS_KEY=<YOUR_S3_ACCESS_KEY>
S3_SECRET_KEY=<YOUR_S3_SECRET_KEY>

# CELERY CONFIGURATION
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# AI PROVIDER CONFIGURATION
# Options: ollama, gemini
AI_PROVIDER="ollama"
OLLAMA_MODEL="gemma3:12b"
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
